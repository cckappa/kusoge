[style name="object_info"]
if {MapStates.memory.guarida_abierta} == false:
	un pedazo de madera para cubrir la entrada a tu guarida
	- mover
		[signal arg_type="dict" arg="{"name":"abrir_guarida"}"]
		set {MapStates.memory.guarida_abierta} = true
	- ignorar
		luego vengo
else:
	¿quieres cerrar tu guarida?
	- sí, cerrar
		[signal arg_type="dict" arg="{"name":"cerrar_guarida"}"]
		set {MapStates.memory.guarida_abierta} = false
	- nah, vuelvo rápido
